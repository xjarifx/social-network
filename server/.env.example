# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Individual resource switches - set to true/false for each resource
# true = use PROD value, false = use DEV value
# No global switch - each resource is independent!

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
CACHE_ENABLED=true

# ============================================
# DATABASE CONFIGURATION
# ============================================
USE_PROD_DATABASE=false

# Production Database (Cloud - e.g., Aiven, Supabase, Neon)
DATABASE_URL_PROD=postgresql://user:password@production-host:5432/social_network_prod

# Development Database (Local)
DATABASE_URL_DEV=postgresql://postgres:password@localhost:5432/social_network_local

# Docker Database Config (for local development only)
POSTGRES_DB=social_network_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5432

# ============================================
# REDIS/CACHE CONFIGURATION
# ============================================
USE_PROD_REDIS=false

# Production Redis (Cloud - e.g., Upstash, Redis Cloud, Aiven Valkey)
REDIS_URL_PROD=redis://:password@production-host:6379

# Development Redis (Local Docker)
REDIS_URL_DEV=redis://:password@localhost:6379

# Docker Redis Config (for local development only)
REDIS_PASSWORD=your_password
REDIS_PORT=6379

# ============================================
# FRONTEND CONFIGURATION
# ============================================
USE_PROD_FRONTEND=false

# Production Frontend URL (e.g., Vercel deployment)
FRONTEND_URL_PROD=https://your-frontend-domain.vercel.app

# Development Frontend URL
FRONTEND_URL_DEV=http://localhost:5173

# ============================================
# BACKEND CONFIGURATION
# ============================================
USE_PROD_BACKEND=false

# Production Backend URL (e.g., Render deployment)
BACKEND_URL_PROD=https://your-api-domain.onrender.com

# Development Backend URL
BACKEND_URL_DEV=http://localhost:3000

# ============================================
# IMAGEKIT CONFIGURATION
# ============================================
USE_PROD_IMAGEKIT=true

# Production ImageKit (https://imagekit.io)
IMAGEKIT_PUBLIC_KEY_PROD=public_your_public_key
IMAGEKIT_PRIVATE_KEY_PROD=private_your_private_key
IMAGEKIT_URL_ENDPOINT_PROD=https://ik.imagekit.io/your_imagekit_id

# Development ImageKit (optional - falls back to prod if not set)
IMAGEKIT_PUBLIC_KEY_DEV=public_your_dev_public_key
IMAGEKIT_PRIVATE_KEY_DEV=private_your_dev_private_key
IMAGEKIT_URL_ENDPOINT_DEV=https://ik.imagekit.io/your_dev_id

# ============================================
# JWT AUTHENTICATION
# ============================================
USE_PROD_JWT=false

# Production JWT Secrets (CHANGE THESE IN PRODUCTION!)
# Generate strong secrets: openssl rand -base64 32
JWT_SECRET_PROD=your_production_jwt_secret_change_this
REFRESH_TOKEN_SECRET_PROD=your_production_refresh_secret_change_this

# Development JWT Secrets
JWT_SECRET_DEV=dev_jwt_secret_for_local_testing
REFRESH_TOKEN_SECRET_DEV=dev_refresh_secret_for_local_testing

# JWT Configuration (same for both environments)
JWT_EXPIRES_IN=5m
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
USE_PROD_STRIPE=true

# Production Stripe Keys (https://stripe.com)
STRIPE_SECRET_KEY_PROD=sk_live_your_live_stripe_secret_key
STRIPE_PUBLIC_KEY_PROD=pk_live_your_live_stripe_public_key
STRIPE_WEBHOOK_SECRET_PROD=whsec_your_live_webhook_secret

# Development Stripe Keys (test mode)
STRIPE_SECRET_KEY_DEV=sk_test_your_test_stripe_secret_key
STRIPE_PUBLIC_KEY_DEV=pk_test_your_test_stripe_public_key
STRIPE_WEBHOOK_SECRET_DEV=whsec_your_test_webhook_secret

# Stripe Product Configuration (same for both environments)
STRIPE_PRO_PRICE_ID=price_your_stripe_price_id
STRIPE_PRO_PRICE_CENTS=999
STRIPE_PRO_CURRENCY=usd
STRIPE_TEST_TRIAL_SECONDS=0

# Stripe URLs (auto-generated from FRONTEND_URL if not specified)
# Override only if you need custom URLs different from your frontend
# STRIPE_SUCCESS_URL_PROD=https://your-frontend-domain.com/billing/success
# STRIPE_CANCEL_URL_PROD=https://your-frontend-domain.com/billing/cancel
# STRIPE_SUCCESS_URL_DEV=http://localhost:5173/billing/success
# STRIPE_CANCEL_URL_DEV=http://localhost:5173/billing/cancel

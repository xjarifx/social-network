# Environment switch: development | production
APP_ENV=development

# Optional mode-specific ports (PORT_<MODE> wins over PORT)
PORT=3000
PORT_DEV=3000
PORT_PROD=3000

# Database URLs
DATABASE_URL_DEV=postgresql://postgres:CHANGE_ME@localhost:5432/social_network_local
DATABASE_URL_PROD=postgresql://user:password@host:5432/social_network?sslmode=require

# Redis URLs
REDIS_URL_DEV=redis://:CHANGE_ME@localhost:6379
REDIS_URL_PROD=rediss://default:CHANGE_ME@your-redis-host:6379

# Frontend URLs (used by CORS / billing redirects)
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://your-frontend-domain.com

# Optional backend URL values for external integrations
BACKEND_URL_DEV=http://localhost:3000
BACKEND_URL_PROD=https://api.yourdomain.com

# Cloudinary (same value for both by default)
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_URL=cloudinary://YOUR_KEY:YOUR_SECRET@YOUR_CLOUD_NAME

# Auth
JWT_EXPIRES_IN=5m
JWT_SECRET=YOUR_STRONG_JWT_SECRET
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=YOUR_REFRESH_TOKEN_SECRET

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRO_PRICE_ID=price_YOUR_PRICE_ID
STRIPE_PRO_PRICE_CENTS=999
STRIPE_PRO_CURRENCY=usd
STRIPE_TEST_TRIAL_SECONDS=0
STRIPE_SUCCESS_URL=http://localhost:3000/api/v1/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/api/v1/billing/cancel

# Optional cache switch
CACHE_ENABLED=true

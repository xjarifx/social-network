# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Individual resource switches - set to true/false for each resource
# true = use PROD value, false = use DEV value

# ============================================
# API CONFIGURATION
# ============================================
USE_PROD_API=false

# Production API URL (e.g., Render deployment)
VITE_API_URL_PROD=https://your-api-domain.onrender.com/api/v1

# Development API URL (local server)
VITE_API_URL_DEV=http://localhost:3000/api/v1

# ============================================
# STRIPE CONFIGURATION
# ============================================
USE_PROD_STRIPE=true

# Production Stripe Public Key (https://stripe.com)
VITE_STRIPE_PUBLIC_KEY_PROD=pk_live_YOUR_LIVE_STRIPE_PUBLIC_KEY

# Development Stripe Public Key (test mode)
VITE_STRIPE_PUBLIC_KEY_DEV=pk_test_YOUR_TEST_STRIPE_PUBLIC_KEY


